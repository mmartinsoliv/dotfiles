#!/usr/bin/env bash

# ============================================
# Claude Code Session Cost Tracker
# ============================================
# Tracks Claude Code CLI sessions and estimates costs
# Usage: claude-cost-tracker [start|stop|status|reset]

set -euo pipefail

SESSION_FILE="/tmp/claude-session-$(whoami).json"
COST_LOG="$HOME/.claude-cost-log"

# Claude API pricing (approximate, per 1M tokens)
# These are estimates - actual costs may vary
declare -A PRICING=(
  ["opus-input"]=15.00
  ["opus-output"]=75.00
  ["sonnet-input"]=3.00
  ["sonnet-output"]=15.00
  ["haiku-input"]=0.25
  ["haiku-output"]=1.25
)

cmd_start() {
  local model="${1:-opus}"
  local start_time=$(date +%s)
  
  cat > "$SESSION_FILE" <<EOF
{
  "start_time": $start_time,
  "model": "$model",
  "input_tokens": 0,
  "output_tokens": 0,
  "status": "active"
}
EOF
  echo "Claude session started ($(date '+%H:%M:%S'))"
}

cmd_stop() {
  if [[ ! -f "$SESSION_FILE" ]]; then
    echo "No active session"
    return 1
  fi
  
  local end_time=$(date +%s)
  local start_time=$(jq -r '.start_time // 0' "$SESSION_FILE" 2>/dev/null || echo 0)
  local duration=$((end_time - start_time))
  local model=$(jq -r '.model // "unknown"' "$SESSION_FILE" 2>/dev/null || echo "unknown")
  local input_tokens=$(jq -r '.input_tokens // 0' "$SESSION_FILE" 2>/dev/null || echo 0)
  local output_tokens=$(jq -r '.output_tokens // 0' "$SESSION_FILE" 2>/dev/null || echo 0)
  
  # Estimate cost (this is a rough estimate)
  local cost=0
  if [[ "$model" == "opus" ]]; then
    cost=$(echo "scale=4; ($input_tokens / 1000000 * 15) + ($output_tokens / 1000000 * 75)" | bc 2>/dev/null || echo 0)
  elif [[ "$model" == "sonnet" ]]; then
    cost=$(echo "scale=4; ($input_tokens / 1000000 * 3) + ($output_tokens / 1000000 * 15)" | bc 2>/dev/null || echo 0)
  elif [[ "$model" == "haiku" ]]; then
    cost=$(echo "scale=4; ($input_tokens / 1000000 * 0.25) + ($output_tokens / 1000000 * 1.25)" | bc 2>/dev/null || echo 0)
  fi
  
  # Format duration
  local duration_str=""
  if (( duration >= 3600 )); then
    local hours=$((duration / 3600))
    local mins=$(((duration % 3600) / 60))
    duration_str="${hours}h ${mins}m"
  elif (( duration >= 60 )); then
    local mins=$((duration / 60))
    local secs=$((duration % 60))
    duration_str="${mins}m ${secs}s"
  else
    duration_str="${duration}s"
  fi
  
  # Log session
  cat >> "$COST_LOG" <<EOF
$(date '+%Y-%m-%d %H:%M:%S') | Model: $model | Duration: $duration_str | Est. Cost: \$$cost
EOF
  
  # Remove session file
  rm -f "$SESSION_FILE"
  
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  Claude Session Summary"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  Model:    $model"
  echo "  Duration: $duration_str"
  echo "  Est. Cost: \$$cost"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
}

cmd_status() {
  if [[ ! -f "$SESSION_FILE" ]]; then
    echo "No active Claude session"
    return 1
  fi
  
  local start_time=$(jq -r '.start_time // 0' "$SESSION_FILE" 2>/dev/null || echo 0)
  local model=$(jq -r '.model // "unknown"' "$SESSION_FILE" 2>/dev/null || echo "unknown")
  
  if (( start_time == 0 )); then
    echo "Invalid session data"
    return 1
  fi
  
  local current_time=$(date +%s)
  local duration=$((current_time - start_time))
  
  # Format duration
  local duration_str=""
  if (( duration >= 3600 )); then
    local hours=$((duration / 3600))
    local mins=$(((duration % 3600) / 60))
    duration_str="${hours}h ${mins}m"
  elif (( duration >= 60 )); then
    local mins=$((duration / 60))
    local secs=$((duration % 60))
    duration_str="${mins}m ${secs}s"
  else
    duration_str="${duration}s"
  fi
  
  echo "Claude ($model) - $duration_str"
}

cmd_tmux_status() {
  if [[ ! -f "$SESSION_FILE" ]]; then
    return 1
  fi
  
  local start_time=$(jq -r '.start_time // 0' "$SESSION_FILE" 2>/dev/null || echo 0)
  local model=$(jq -r '.model // "?"' "$SESSION_FILE" 2>/dev/null || echo "?")
  
  if (( start_time == 0 )); then
    return 1
  fi
  
  local current_time=$(date +%s)
  local duration=$((current_time - start_time))
  
  local mins=$((duration / 60))
  local secs=$((duration % 60))
  
  printf "#[fg=#fcee0a,bold]⬤#[default] Claude %s %02d:%02d" "$model" "$mins" "$secs"
}

cmd_reset() {
  rm -f "$SESSION_FILE"
  echo "Session reset"
}

cmd_total() {
  if [[ ! -f "$COST_LOG" ]]; then
    echo "No cost history found"
    return 1
  fi
  
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  Claude Cost History"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  tail -n 20 "$COST_LOG"
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
}

# Main
case "${1:-status}" in
  start)
    cmd_start "${2:-opus}"
    ;;
  stop)
    cmd_stop
    ;;
  status)
    cmd_status
    ;;
  tmux)
    cmd_tmux_status
    ;;
  reset)
    cmd_reset
    ;;
  total)
    cmd_total
    ;;
  *)
    echo "Usage: $(basename "$0") [start|stop|status|tmux|reset|total]"
    exit 1
    ;;
esac