#!/usr/bin/env bash

# ============================================
# AI Agent Notification Script
# ============================================
# Usage: ai-notify [type] [message] [agent]
# Types: done, waiting, error, info
# Agents: claude, cursor, opencode (auto-detected if not provided)

set -euo pipefail

TYPE="${1:-done}"
MESSAGE="${2:-}"
AGENT="${3:-}"

# Resolve display name for agent
case "$AGENT" in
  claude) AGENT_NAME="Claude" ;;
  cursor) AGENT_NAME="Cursor" ;;
  opencode) AGENT_NAME="OpenCode" ;;
  *) AGENT_NAME="${AGENT:-Agent}" ;;
esac

# Default messages per type
case "$TYPE" in
  done)
    SOUND="default"
    DEFAULT_MSG="Task completed"
    TITLE="$AGENT_NAME ✅"
    ;;
  waiting)
    SOUND="default"
    DEFAULT_MSG="Need your attention"
    TITLE="$AGENT_NAME ⏳"
    ;;
  error)
    SOUND="Basso"
    DEFAULT_MSG="Something went wrong"
    TITLE="$AGENT_NAME ❌"
    ;;
  info)
    SOUND="Pop"
    DEFAULT_MSG="FYI"
    TITLE="$AGENT_NAME 💡"
    ;;
  *)
    SOUND="default"
    DEFAULT_MSG="Notification"
    TITLE="$AGENT_NAME"
    ;;
esac

# Use provided message or default
NOTIFICATION_MSG="${MESSAGE:-$DEFAULT_MSG}"

# Build osascript command
NOTIFY_CMD="osascript -e 'display notification \"$NOTIFICATION_MSG\" with title \"$TITLE\" sound name \"$SOUND\"'"

# If running in tmux, use reattach-to-user-namespace
if [ -n "${TMUX:-}" ] && command -v reattach-to-user-namespace &> /dev/null; then
  NOTIFY_CMD="reattach-to-user-namespace $NOTIFY_CMD"
fi

# Execute notification
eval "$NOTIFY_CMD" 2>/dev/null || true

# Also play sound as fallback
afplay "/System/Library/Sounds/${SOUND}.aiff" 2>/dev/null || true
