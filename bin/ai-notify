#!/usr/bin/env bash

# ============================================
# AI Agent Notification Script
# ============================================
# Usage: ai-notify [type] [message] [agent]
# Types: done, waiting, error, info
# Agents: claude, cursor, opencode (auto-detected if not provided)

set -euo pipefail

TYPE="${1:-done}"
MESSAGE="${2:-}"
AGENT="${3:-}"

# Resolve display name for agent
case "$AGENT" in
  claude) AGENT_NAME="Claude" ;;
  cursor) AGENT_NAME="Cursor" ;;
  opencode) AGENT_NAME="OpenCode" ;;
  *) AGENT_NAME="${AGENT:-Agent}" ;;
esac

# Default messages per type
case "$TYPE" in
  done)
    SOUND="/System/Library/Sounds/Blow.aiff"
    DEFAULT_MSG="Task completed"
    TITLE="$AGENT_NAME ✅"
    ;;
  waiting)
    SOUND="/System/Library/Sounds/Blow.aiff"
    DEFAULT_MSG="Need your attention"
    TITLE="$AGENT_NAME ⏳"
    ;;
  error)
    SOUND="/System/Library/Sounds/Basso.aiff"
    DEFAULT_MSG="Something went wrong"
    TITLE="$AGENT_NAME ❌"
    ;;
  info)
    SOUND="/System/Library/Sounds/Pop.aiff"
    DEFAULT_MSG="FYI"
    TITLE="$AGENT_NAME 💡"
    ;;
  *)
    SOUND="/System/Library/Sounds/Blow.aiff"
    DEFAULT_MSG="Notification"
    TITLE="$AGENT_NAME"
    ;;
esac

# Use provided message or default
NOTIFICATION_MSG="${MESSAGE:-$DEFAULT_MSG}"

# Play sound (suppress errors)
afplay "$SOUND" 2>/dev/null || true

# Send macOS notification
osascript -e "display notification \"$NOTIFICATION_MSG\" with title \"$TITLE\" sound name \"$SOUND\"" 2>/dev/null || true